# ===========================================================================
# PUMA Helpdesk — Variables d'environnement Docker
# Copier ce fichier en .env.docker et compléter les valeurs
# ===========================================================================

# ── Base de données ──────────────────────────────────────────────────────────
DB_NAME=puma_helpdesk
DB_USER=puma_user
# OBLIGATOIRE : choisir un mot de passe fort
DB_PASSWORD=CHANGEZ_MOI_mot_de_passe_fort_123!

# ── Sécurité des sessions ─────────────────────────────────────────────────────
# OBLIGATOIRE : générer avec : openssl rand -base64 64
SESSION_SECRET=CHANGEZ_MOI_cle_secrete_tres_longue_a_generer_avec_openssl

# ── Réseau ───────────────────────────────────────────────────────────────────
# Port HTTP exposé sur l'hôte (80 par défaut)
# Changer si le port 80 est déjà utilisé par une autre application
HTTP_PORT=80
